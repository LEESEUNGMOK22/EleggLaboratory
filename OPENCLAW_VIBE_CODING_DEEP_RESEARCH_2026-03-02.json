      "tool policy (allow/deny/profile) is the main risk-control plane",
      "exec/process provide strong automation with approval controls",
      "subagent (native) and acp (external harness) should be used for different intents"
    ],
    "constraints": {
      "technical": [
        "api-key dependencies for web_search",
        "remote chat vs local GUI visibility gap",
        "long-running process management overhead",
        "policy mismatch can cause unexpected behavior"
      ],
      "operational": [
        "auth bottlenecks for git/channel/api actions",
        "personal-assistant trust model is not hostile multi-tenant isolation",
        "secret leakage risk in chat/logs"
      ],
      "quality": [
        "cognitive debt from unreviewed generated code",
        "maintenance and test debt",
        "security flaws if verification is skipped"
      ]
    },
    "vibe_coding": {
      "strengths": [
        "rapid prototyping",
        "fast iteration loop",
        "good for small/internal apps"
      ],
      "weaknesses": [
        "opaque code ownership",
        "fragile architecture drift",
        "higher risk in critical production paths"
      ],
      "best_fit": [
        "prototype",
        "internal tools",
        "automation scripts",
        "small product experiments"
      ],
      "not_best_fit_without_hardening": [
        "payment/auth core paths",
        "high-compliance domains",
        "large long-lived complex systems"
      ]
    }
  },
  "recommended_workflow": [
    "validate environment and toolchain",
    "start with small template/sample",
    "apply minimal scoped changes",
    "run analyze/test/run on each step",
    "record execution evidence/log summary",
    "commit with rationale",
